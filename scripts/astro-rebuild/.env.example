# ── Webhook receiver configuration ───────────────────────────────────────────
# Copy to .env and fill in the values for each environment.
# This file is loaded by the systemd service via EnvironmentFile=.

# Port this server listens on.
# Production:  9000
# Staging:     9001
WEBHOOK_PORT=9000

# Shared HMAC secret — must match STATIC_SITE_WEBHOOK_SECRET in Laravel .env.
WEBHOOK_SECRET=change-me-in-production

# Absolute path to the Astro project root (where package.json lives).
# The build command runs here: npm run build -- --outDir <releaseDir>
# Development: /home/<user>/projects/website-claesen-v1
# Production:  /var/www/astro-source/website-claesen-v1
WEBHOOK_PROJECT_DIR=/var/www/astro-source/website-claesen-v1

# Where versioned release directories are stored.
# Development:  ./.deploy/releases
# Staging:      /var/www/claesen-verlichting-staging/v1/releases
# Production:   /var/www/claesen-verlichting/v1/releases
WEBHOOK_RELEASES_DIR=/var/www/claesen-verlichting/v1/releases

# Symlink that points to the active release (your web server's document root).
# Development:  ./.deploy/current
# Staging:      /var/www/claesen-verlichting-staging/v1/current
# Production:   /var/www/claesen-verlichting/v1/current
WEBHOOK_CURRENT_LINK=/var/www/claesen-verlichting/v1/current

# Environment label sent back in /health and logged.
# production | staging | development
WEBHOOK_ENV=production

# npm script to run (default: build → runs "npm run build").
WEBHOOK_NPM_SCRIPT=build

# Number of old releases to keep. The current release is never pruned.
WEBHOOK_KEEP_RELEASES=5

# Maximum age (seconds) of an acceptable HMAC timestamp. Must match
# STATIC_SITE_SIGNATURE_TOLERANCE_SECONDS in Laravel static_site config.
WEBHOOK_SIGNATURE_TOLERANCE=300
